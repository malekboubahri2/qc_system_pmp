# Painting QC — infra environment variables
# Used by docker-compose.dev.yml and docker-compose.prod.yml.
# Copy to .env and fill in real values. Never commit .env.

# ── Server ────────────────────────────────────────────────────
DATABASE_URL=sqlite:////var/lib/qc/qc.db
JWT_SECRET=change-me-minimum-32-chars
JWT_EXPIRY_SECONDS=3600

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=qc-server
MQTT_PASSWORD=change-me

ENABLE_MQTT_TLS=false
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173
FEATURE_FLAGS_REFRESH_SECS=30

# ── Mosquitto ─────────────────────────────────────────────────
# Used by the healthcheck inside the mosquitto container.
# Must match the password set via mosquitto_passwd.
MQTT_SERVER_PASSWORD=change-me
