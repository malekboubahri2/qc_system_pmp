# Painting QC — infra environment variables
# Used by docker-compose.dev.yml and docker-compose.prod.yml.
# Copy to .env and fill in real values. Never commit .env.

# ── Server ────────────────────────────────────────────────────
DATABASE_URL=sqlite:////var/lib/qc/qc.db
JWT_SECRET=change-me-minimum-32-chars
JWT_EXPIRY_SECONDS=3600

MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=qc-server
MQTT_PASSWORD=change-me

ENABLE_MQTT_TLS=false
LOG_LEVEL=INFO
CORS_ALLOWED_ORIGINS=http://localhost:5173
FEATURE_FLAGS_REFRESH_SECS=30

# ── Mosquitto ─────────────────────────────────────────────────
# Used by the healthcheck inside the mosquitto container.
# Must match the password set via mosquitto_passwd.
MQTT_SERVER_PASSWORD=change-me

# ── Local DNS (dnsmasq) ───────────────────────────────────────
# Friendly hostnames for the platform on the plant LAN. dnsmasq resolves each to
# the RPi's *current* DHCP-assigned IP (no hardcoded address). Space-separated
# list — every name points at the Pi. The platform lives at
# https://inspection.pmp.com/level3/ ; the public andon wall display at
# https://andon.pmp.com/ (see docs/deployment.md).
QC_DOMAIN=inspection.pmp.com andon.pmp.com
# Hostname Caddy serves the public andon dashboard on (must be one of QC_DOMAIN).
ANDON_DOMAIN=andon.pmp.com
# Upstream resolver for every other name. On a LAN with no internet, set this to
# the plant gateway/router so non-QC lookups still resolve.
UPSTREAM_DNS=1.1.1.1
# LAN_IFACE=eth0   # optional — auto-detected from the default route if unset
