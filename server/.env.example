# Painting QC — server environment variables
# Copy to .env and fill in real values. Never commit .env.

# Database (SQLite on named volume)
DATABASE_URL=sqlite:////var/lib/qc/qc.db

# JWT — generate with: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=change-me-minimum-32-chars
JWT_EXPIRY_SECONDS=3600

# MQTT broker
MQTT_HOST=mosquitto
MQTT_PORT=1883
MQTT_USERNAME=qc-server
MQTT_PASSWORD=change-me

# TLS (disabled for PoC; enable when deploying with cert)
ENABLE_MQTT_TLS=false

# Logging
LOG_LEVEL=INFO

# CORS — comma-separated, no trailing slash
CORS_ALLOWED_ORIGINS=http://localhost:5173

# Feature flags cache TTL (seconds)
FEATURE_FLAGS_REFRESH_SECS=30

# Auto-generated operator PIN length (4–8 digits) — legacy, MQTT config only
OPERATOR_PIN_LENGTH=6

# Auto-generated operator login password length (6–24 chars) — ADR-018
OPERATOR_PASSWORD_LENGTH=8
