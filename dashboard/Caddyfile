{
	admin off
	# Keep plain HTTP on :80 working (no forced redirect to HTTPS).
	auto_https disable_redirects
	# On-demand internal TLS: issue a cert for whatever host/IP the tablet uses
	# (the Pi's address changes between networks). The closed LAN has no public
	# CA; the server health endpoint returns 200 for any host, so it acts as a
	# permissive allow-list for on-demand issuance.
	on_demand_tls {
		ask http://{env.API_HOST}/health
	}
}

# Shared site handlers (served over both HTTP and HTTPS).
(site) {
	root * /usr/share/caddy

	# Inject runtime config so the built JS can read API URL, plant name, locale
	handle /config.js {
		header Content-Type "application/javascript"
		respond `window.__APP_CONFIG__ = {
  "apiBaseUrl": "/api",
  "plantName": "{env.PLANT_NAME}",
  "locale": "{env.LOCALE}"
};`
	}

	# Proxy API calls to the FastAPI server (strips /api prefix)
	handle /api/* {
		uri strip_prefix /api
		reverse_proxy {env.API_HOST} {
			# Flush immediately so Server-Sent Events (/api/events) stream
			# through instead of being buffered.
			flush_interval -1
		}
	}

	# SPA fallback — always serve index.html for unknown paths
	handle {
		try_files {path} /index.html
		file_server
	}

	encode gzip
}

# HTTP (kept working; also lets the tablet reach the CA download below).
:80 {
	import site
}

# HTTPS with Caddy's internal CA — required for the PWA to be installable,
# load offline (service worker), and use the screen wake-lock. Install the root
# CA on the tablet once (see docs/runbook-kiosk.md).
:443 {
	tls {
		issuer internal
		on_demand
	}
	import site
}
