{
	admin off
	# Keep plain HTTP on :80 working (no forced redirect to HTTPS).
	auto_https disable_redirects
	# On-demand internal TLS: issue a cert for whatever host/IP the client uses
	# (the Pi's address changes between networks, and we serve several hostnames:
	# inspection.pmp.com, andon.pmp.com, the raw IP). The server health endpoint
	# returns 200 for any host, so it acts as a permissive allow-list for issuance.
	on_demand_tls {
		ask http://{env.API_HOST}/health
	}
}

# ── The platform under the /level3 base + its API ─────────────────────────────
# Both hostnames serve the static bundle (built with Vite base=/level3/) under
# /level3, so asset URLs resolve the same everywhere. config.js advertises the
# API at /level3/api; the andon page's address bar stays clean because andon.html
# is served at the host root while its assets live under /level3.
(level3) {
	# Runtime config — apiBaseUrl sits under the same base.
	handle /level3/config.js {
		header Content-Type "application/javascript"
		respond `window.__APP_CONFIG__ = {
  "apiBaseUrl": "/level3/api",
  "plantName": "{env.PLANT_NAME}",
  "locale": "{env.LOCALE}"
};`
	}

	# API proxy (strip /level3/api → FastAPI). flush_interval -1 keeps SSE flowing.
	handle /level3/api/* {
		uri strip_prefix /level3/api
		reverse_proxy {env.API_HOST} {
			flush_interval -1
		}
	}

	# Static bundle + assets (strip /level3, SPA fallback to index.html).
	handle_path /level3/* {
		root * /usr/share/caddy
		try_files {path} /index.html
		file_server
	}
}

# ── Site routes, shared by :80 and :443 ───────────────────────────────────────
(routes) {
	# Public, no-login andon wall display on its own hostname.
	@andon host {env.ANDON_DOMAIN}
	handle @andon {
		import level3
		# Host root (and anything else) → the andon single-page app.
		handle {
			root * /usr/share/caddy
			rewrite * /andon.html
			file_server
		}
	}

	# Everything else (inspection.pmp.com, the raw Pi IP): the platform.
	handle {
		import level3
		# Public andon board reachable by raw IP (or any host) without DNS:
		# http://<pi-ip>/andon. Its /level3/* assets + API are served by the
		# import above, so only the page itself needs this route.
		handle /andon* {
			root * /usr/share/caddy
			rewrite * /andon.html
			file_server
		}
		# Bare root / stray paths → the app under /level3. Use 307 (temporary),
		# NOT 308 (permanent): browsers cache a 308 forever, so if another host
		# (e.g. andon.pmp.com) ever transiently hits this redirect, it gets stuck
		# pointing at /level3 in that browser. The explicit `*` matcher is
		# required — `redir /level3/ 307` would parse /level3/ as a path matcher.
		handle {
			redir * /level3/ 307
		}
	}

	encode gzip
}

# HTTP (kept working; also lets a tablet reach the CA download).
:80 {
	import routes
}

# HTTPS with Caddy's internal CA — required for the PWA to be installable,
# load offline (service worker), and use the screen wake-lock. Install the root
# CA on the tablet once (see docs/runbook-kiosk.md).
:443 {
	tls {
		issuer internal
		on_demand
	}
	import routes
}
